{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and player",
  "windows": [
    "main",
    "player_window"
  ],
  "remote": {
    "urls": [
      "http://*/*",
      "https://*/*"
    ]
  },
  "permissions":[
    "core:default",
    "opener:default",
    "core:window:default",
    "core:webview:default",
    "core:event:default",
    "log:default"
  ]
}